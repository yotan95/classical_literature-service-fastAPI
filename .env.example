# .env.example — 환경변수 설정 키 템플릿.
# 실제 .env는 git에 커밋하지 않으며, RPi에서는 clone 후 이 파일을 복사해 값만 채운다.
#   cp .env.example .env
# 키 값(특히 ANTHROPIC_API_KEY)은 절대 실제 값을 적지 말 것 — 마스킹/빈 값만 유지.

# 바인드 호스트 (휴대폰/태블릿에서 접근하려면 0.0.0.0)
HOST=0.0.0.0
# 포트
PORT=8000

# Claude API 키 — 절대 커밋 금지. 실제 키는 .env에만 입력 (예: sk-ant-***)
ANTHROPIC_API_KEY=

# 사용할 Claude 모델 (Sonnet 4.6)
CLAUDE_MODEL=claude-sonnet-4-6

# 원작 데이터 루트
DATA_DIR=app/data

# CORS 허용 오리진 — 개발 중에는 * (콤마로 여러 개 지정 가능), 배포 시 좁힌다
CORS_ORIGINS=*

# 오디오극 음성 합성용 Google Cloud 서비스계정 JSON 경로. 절대 커밋 금지.
# 비워두면 ADC(gcloud 기본 인증)를 시도하고, 둘 다 없으면 audio 모드 합성 시 명확히 실패한다.
GOOGLE_APPLICATION_CREDENTIALS=
# 합성 MP3 캐시/서빙 루트 — /audio 정적 경로로 노출된다
AUDIO_DIR=app/audio

# 표지 이미지 생성용 OpenAI 키 — 절대 커밋 금지. 실제 키는 .env에만 입력 (예: sk-***).
# 비우면 책 표지(/images)·창작물 표지(/creation-covers)가 생성되지 않고 null로 응답된다(창작 자체는 성공).
OPENAI_API_KEY=
# 표지 이미지 모델/크기/품질 (기본값 사용 가능 — 보통 그대로 둔다)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=800x1120
OPENAI_IMAGE_QUALITY=low
# 창작물 고유 표지 webp 저장 루트 — /creation-covers 정적 경로로 노출된다
CREATION_COVER_DIR=app/creation_covers

# 어려운 단어 풀이용 국립국어원 한국어기초사전(krdict) Open API 인증키 — 절대 커밋 금지.
# 비우면 단어풀이(POST /vocab + 창작 결과 임베드 glossary)가 실패한다(창작 본문 생성은 영향 없음).
KRDICT_API_KEY=
